[rx]
# RadioMaster XR via external CP2102 at the standard CRSF baud used by the FC.
# by-path names: both CP2102s report serial "0001" so by-id collides and ttyUSB
# numbering swaps on replug. These are stable per physical USB socket.
port = /dev/serial/by-path/pci-0000:02:00.0-usb-0:9:1.0-port0
baud = 420000

[tx]
# RadioMaster Nomad USB-C (internal CP2102 -> ESP32 UART0). On the stock layout this
# is flash/debug/reset only: firmware remaps UART0 to the bay pin (GPIO4) at boot.
flash_port = /dev/serial/by-path/pci-0000:02:00.0-usb-0:8:1.0-port0
# hardware.json override APPLIED 2026-07-13 (serial_rx:3/serial_tx:1 — see README):
# USB is the handset port. Revert: esptool erase_region 0x3d0000 0x20000, then clear this.
handset_port = /dev/serial/by-path/pci-0000:02:00.0-usb-0:8:1.0-port0
handset_baud = 921600

[test]
# 20s is plenty for stock ELRS; PrivacyLRS session establishment is currently
# much slower (cold-start LQ alone measured at ~30s), hence the longer window.
timeout_seconds = 75
parameter_timeout_seconds = 3.0
channel_tolerance_us = 8

[fork]
# Firmware source tree and the user_defines.txt containing MY_BINDING_PHRASE.
dir = ../ExpressLRS
binding_defines = ../ExpressLRS/src/user_defines.txt

[unit.nomad]
role = tx
env = Unified_ESP32_LR1121_TX_via_UART
target = radiomaster.tx_dual.nomad
port = /dev/serial/by-path/pci-0000:02:00.0-usb-0:8:1.0-port0
flash_baud = 460800
domain = fcc_915

[unit.xr1]
role = rx
env = Unified_ESP32C3_LR1121_RX_via_UART
target = radiomaster.rx_dual.xr1
port = /dev/serial/by-path/pci-0000:02:00.0-usb-0:9:1.0-port0
# runtime CRSF baud, patched into the image via --rx-baud and used for the
# bl-trigger + in-app-stub flashing path (no reset lines on this adapter)
rx_baud = 420000
domain = fcc_915
